<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  EXAMPLE ONLY — replace with real GoogleService-Info.plist from Firebase Console.

  Steps:
  1. Firebase Console → salonbookingapp-dd24d → Add iOS app
  2. Bundle ID: com.salonbooking.app
  3. Download GoogleService-Info.plist
  4. Save as ios/Runner/GoogleService-Info.plist (remove .example)
  5. Update lib/firebase_options.dart → iosConfigured = true
  6. See docs/IOS_SETUP.md
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>920429460532</string>
	<key>GOOGLE_APP_ID</key>
	<string>1:920429460532:ios:YOUR_APP_ID</string>
	<key>PROJECT_ID</key>
	<string>salonbookingapp-dd24d</string>
	<key>STORAGE_BUCKET</key>
	<string>salonbookingapp-dd24d.firebasestorage.app</string>
	<key>BUNDLE_ID</key>
	<string>com.salonbooking.app</string>
</dict>
</plist>
